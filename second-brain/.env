# App
APP_NAME="Second Brain"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Security — CHANGE IN PRODUCTION
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Redis
REDIS_URL=redis://redis:6379
REDIS_STREAM_ACTIONS=stream:actions
REDIS_STREAM_TRIGGERS=stream:triggers

# Vector store (ChromaDB)
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=second_brain
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5

# Vault
VAULT_PATH=/vault

# Confirmation gate
GATE_TIMEOUT_SECONDS=300
GATE_REQUIRE_CONFIRMATION=true

# Frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Phase 2: external APIs (do not fill yet) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GOOGLE_CALENDAR_CREDENTIALS=
# AMADEUS_API_KEY=
# AMAZON_ACCESS_KEY=
