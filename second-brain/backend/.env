# Local development — uvicorn reads this from backend/
# Start infrastructure first: docker-compose up redis chromadb
# Then: cd backend && python -m uvicorn main:app --reload

APP_NAME="Second Brain"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=DEBUG

HOST=0.0.0.0
PORT=8000

SECRET_KEY=dev-secret-key-change-before-production

# Redis — Docker exposes 6379 on localhost
REDIS_URL=redis://localhost:6379
REDIS_STREAM_ACTIONS=stream:actions
REDIS_STREAM_TRIGGERS=stream:triggers

# ChromaDB — Docker exposes 8001 on localhost (internal container port is 8000)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=second_brain
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5

# Vault — relative to backend/ directory
VAULT_PATH=../vault

GATE_TIMEOUT_SECONDS=300
GATE_REQUIRE_CONFIRMATION=true

ALLOWED_ORIGINS=["http://localhost:3000"]

# Phase 2 — fill when needed
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GOOGLE_CALENDAR_CREDENTIALS=
# AMADEUS_API_KEY=
# AMAZON_ACCESS_KEY=
