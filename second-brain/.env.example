# =============================================================================
# Second Brain — environment template
# =============================================================================
# LOCAL DEV (recommended):
#   1. Copy this file to backend/.env
#   2. Run: docker-compose up redis chromadb
#   3. Run: cd backend && python -m uvicorn main:app --reload
#
# FULL DOCKER (all services in containers):
#   Change REDIS_URL, CHROMA_HOST to Docker service names (see comments below)
#   Run: docker-compose up
# =============================================================================

# App
APP_NAME="Second Brain"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=DEBUG

# Server
HOST=0.0.0.0
PORT=8000

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Redis
# Local dev (Docker-exposed):  redis://localhost:6379
# Inside Docker network:       redis://redis:6379
REDIS_URL=redis://localhost:6379
REDIS_STREAM_ACTIONS=stream:actions
REDIS_STREAM_TRIGGERS=stream:triggers

# ChromaDB
# Local dev (Docker-exposed):  host=localhost  port=8001
# Inside Docker network:       host=chromadb   port=8000
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=second_brain
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5

# Vault
# Local dev (relative to backend/):  ../vault
# Inside Docker:                      /vault
VAULT_PATH=../vault

# Confirmation gate
GATE_TIMEOUT_SECONDS=300
GATE_REQUIRE_CONFIRMATION=true

# Frontend origins (comma-separated JSON array)
ALLOWED_ORIGINS=["http://localhost:3000"]

# =============================================================================
# Phase 2 — fill when integrating external APIs
# =============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GOOGLE_CALENDAR_CREDENTIALS=
# AMADEUS_API_KEY=
# AMAZON_ACCESS_KEY=
